{
  "name": "invoice-creator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "postinstall": "npm run db:generate",
    "predev": "npm run db:sync",
    "dev": "next dev",
    "prebuild": "npm run db:generate",
    "build": "next build",
    "prestart": "npm run db:sync",
    "start": "next start",
    "prepreview": "npm run db:sync",
    "preview": "next start -p 3000",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:migrate": "wrangler d1 migrations apply invoice-creator-production --remote",
    "cf:migrate:local": "wrangler d1 migrations apply invoice-creator-production --local",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:prepare": "node scripts/prepare-database.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "npm run db:prepare && prisma migrate deploy",
    "db:sync": "npm run db:migrate && npm run db:generate",
    "db:push": "prisma db push",
    "check": "npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
